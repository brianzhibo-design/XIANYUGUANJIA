# ============================================================
# 闲鱼管家 - 环境变量配置
# 复制为 .env 并填入实际值: cp .env.example .env
# ============================================================

# === 闲鱼 Cookie (必填) ===
# 从浏览器 DevTools 获取：打开 goofish.com -> 登录 -> F12 -> Network -> 复制 Cookie
XIANYU_COOKIE_1=your_cookie_here

# === 闲管家开放平台 (必填，也可在前端 /config 页面可视化配置) ===
XGJ_APP_KEY=
XGJ_APP_SECRET=
XGJ_BASE_URL=https://open.goofish.pro

# === AI 模型 (必填，用于自动回复和内容生成) ===
# 支持 OpenAI 兼容 API：DeepSeek / 通义千问 / 智谱 / 火山方舟
AI_PROVIDER=deepseek
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat
AI_TEMPERATURE=0.7

# === CookieCloud (可选，服务器部署时推荐) ===
# 自动从 CookieCloud 同步浏览器 Cookie，无需手动粘贴
# 部署: docker run -p=8088:8088 easychen/cookiecloud:latest
# Chrome/Edge 安装 CookieCloud 插件，配置同步域名关键词包含 goofish
# COOKIE_CLOUD_HOST=http://your-server:8088
# COOKIE_CLOUD_UUID=your-uuid-from-plugin
# COOKIE_CLOUD_PASSWORD=your-password-from-plugin

# === 消息自动回复 (默认启用) ===
# 设为 false 可关闭自动回复功能
MESSAGES_ENABLED=true

# === Cookie 加密 (可选，不设置则自动生成) ===
# ENCRYPTION_KEY=your_secret_passphrase

# === 数据库 (Python 后端使用 SQLite，无需额外配置) ===
DATABASE_URL=sqlite:///data/agent.db

# === 端口配置 ===
PYTHON_PORT=8091
FRONTEND_PORT=5173
