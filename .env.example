# ============================================================
# 闲鱼管家 (OpenClaw) — 环境变量配置
# 复制为 .env 并填入实际值: cp .env.example .env
#
# 配置优先级: 默认值 < config.yaml < system_config.json(管理面板) < .env / 环境变量
# 大部分配置也可在管理面板「系统配置」中可视化设置
# ============================================================

# ┌──────────────────────────────────────────────┐
# │  第一步：填下面 3 项就能跑起来（最小配置）     │
# └──────────────────────────────────────────────┘

# 1) 闲鱼 Cookie（必填）
#    获取方式：打开 goofish.com → 登录 → F12 → Network → 任意请求 → 复制 Cookie 请求头
#    也可启动后在管理面板「账户管理」页面点击「自动获取」
XIANYU_COOKIE_1=your_cookie_here

# 2) AI 配置（必填，用于自动回复和内容生成）
#    推荐 DeepSeek（便宜好用）；也支持通义千问、智谱、火山方舟、OpenAI 等
AI_PROVIDER=deepseek
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# 3) 闲管家开放平台（必填，用于订单/发货/改价）
#    注册：https://open.goofish.pro → 创建应用 → 获取 AppKey/AppSecret
#    也可在管理面板「系统配置 → 闲管家」中填写
XGJ_APP_KEY=
XGJ_APP_SECRET=

# ┌──────────────────────────────────────────────┐
# │  以下均为可选配置，按需启用                     │
# └──────────────────────────────────────────────┘

# === CookieCloud 自动同步（强烈推荐，防止 Cookie 失效中断服务）===
# 服务端已内置，只需安装浏览器扩展即可：
#   Chrome: https://chromewebstore.google.com/detail/cookiecloud/ffjiejobkoibkjlhjnlgmcnnigeelbdl
#   Edge:   https://microsoftedge.microsoft.com/addons/detail/cookiecloud/bkifenclicgpjhgijmepkiielkeondlg
# 安装后在扩展中查看 UUID 和密码，填入下方（或在管理面板「系统配置 → CookieCloud」中配置）
# COOKIE_CLOUD_UUID=
# COOKIE_CLOUD_PASSWORD=

# === Cookie 自动刷新（默认启用，每 30 分钟检查一次）===
COOKIE_AUTO_REFRESH=true
# COOKIE_REFRESH_INTERVAL=30

# === 消息自动回复 ===
MESSAGES_ENABLED=true

# === AI 高级参数 ===
# AI_TEMPERATURE=0.7

# === 端口配置（一般不需要改）===
# PYTHON_PORT=8091
# FRONTEND_PORT=5173

# === 数据库（默认 SQLite，无需额外安装）===
# DATABASE_URL=sqlite:///data/agent.db

# === Cookie 加密密钥（不设置则自动生成）===
# ENCRYPTION_KEY=

# === 闲管家高级 ===
# XGJ_BASE_URL=https://open.goofish.pro
# XGJ_MERCHANT_ID=
# XGJ_AUTO_SHIP_ENABLED=true
# XGJ_AUTO_PRICE_ENABLED=true

# === 阿里云 OSS（商品图片上传，可选）===
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET=
# OSS_ENDPOINT=

# === 飞书告警（可选，收到异常/售后时推送通知）===
# FEISHU_BOT_WEBHOOK=

# === 运行模式 ===
# APP_RUNTIME=auto          # auto(推荐) | lite(纯 Playwright) | pro(需 Browser Gateway)
# APP_LOG_LEVEL=INFO
# APP_ENV=production        # 生产环境请设为 production

# === 自动更新（私有仓库需要 GitHub Token）===
# GITHUB_UPDATE_TOKEN=ghp_xxxx

# === Docker 构建（国内用户加速）===
# MIRROR=china
